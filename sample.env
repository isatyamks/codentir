GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_STORE_PATH=./data/vector_store
COLLECTION_NAME=devasssure_knowledge
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
TOP_K=10
SIMILARITY_THRESHOLD=0.5
HYBRID_ALPHA=0.3
ENABLE_RERANKING=false
RERANK_TOP_K=10
MIN_EVIDENCE_CONFIDENCE=0.5
MAX_CONTEXT_DEVIATION=0.3
ENABLE_HALLUCINATION_GUARD=true
ENABLE_PROMPT_INJECTION_GUARD=true
ENABLE_EVIDENCE_THRESHOLD=true
LLM_TEMPERATURE=0.2
MAX_TOKENS=2000
REQUIRE_JSON_MODE=true
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.txt,.md,.pdf,.docx,.png,.jpg,.jpeg
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=info
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=eng
USE_EASYOCR=false
BATCH_SIZE=32
MAX_WORKERS=4
ENABLE_CACHE=true
CACHE_DIR=./data/cache
LOG_DIR=./logs
LOG_FILE=devasssure.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
DEBUG=false
ENABLE_PROFILING=false
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
GROQ_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx